      "\t\t\t\"mode\": \"debug\",",
      "\t\t\t\"program\": \"\\${workspaceFolder}\",",
      "\t\t\t\"cwd\": \"\\${workspaceFolder}\",",
      "\t\t\t\"args\": [\"serve\", \"--dev\"]",
