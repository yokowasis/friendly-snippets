  "ftp": {
    "prefix": "ftp",
    "body": [
      "import * as ftp from \"basic-ftp\";",
      "import * as fs from \"fs\";",
      "import * as path from \"path\";",
      "",
      "const FTP_HOST = \"next.app.web.id\";",
      "const FTP_USER = \"cdn@next.app.web.id\";",
      "const FTP_PASS = \"aQ24TPufhL4mWugq4YxK\";",
      "const REMOTE_BASE_PATH = \"/\";",
      "",
      "async function ensureRemoteDir(client: ftp.Client, dirPath: string) {",
      "  const parts = dirPath.split(\"/\").filter((p) => p.length > 0);",
      "  let currentPath = \"\";",
      "",
      "  for (const part of parts) {",
      "    currentPath += \"/\" + part;",
      "    try {",
      "      await client.cd(currentPath);",
      "    } catch {",
      "      await client.ensureDir(currentPath);",
      "    }",
      "  }",
      "}",
      "",
      "async function uploadDirectory(",
      "  client: ftp.Client,",
      "  localDir: string,",
      "  remoteDir: string,",
      ") {",
      "  const entries = fs.readdirSync(localDir, { withFileTypes: true });",
      "",
      "  for (const entry of entries) {",
      "    const localPath = path.join(localDir, entry.name);",
      "    const remotePath =",
      "      remoteDir + (remoteDir.endsWith(\"/\") ? \"\" : \"/\") + entry.name;",
      "",
      "    if (entry.isDirectory()) {",
      "      await ensureRemoteDir(client, remotePath);",
      "      await uploadDirectory(client, localPath, remotePath);",
      "    } else {",
      "      await client.uploadFrom(localPath, remotePath);",
      "      console.log(`Uploaded: \\${localPath} -> \\${remotePath}`);",
      "    }",
      "  }",
      "}",
      "",
      "async function deploy(source: string, destination: string) {",
      "  const client = new ftp.Client();",
      "  client.ftp.verbose = true;",
      "",
      "  try {",
      "    await client.access({",
      "      host: FTP_HOST,",
      "      user: FTP_USER,",
      "      password: FTP_PASS,",
      "      secure: false,",
      "    });",
      "",
      "    console.log(`Connected to FTP server: \\${FTP_HOST}`);",
      "",
      "    const remoteDest = path",
      "      .join(REMOTE_BASE_PATH, destination)",
      "      .replace(/\\\\\\/g, \"/\");",
      "    await ensureRemoteDir(client, remoteDest);",
      "",
      "    const sourcePath = path.resolve(source);",
      "    if (!fs.existsSync(sourcePath)) {",
      "      throw new Error(`Source directory does not exist: \\${sourcePath}`);",
      "    }",
      "",
      "    console.log(`Deploying \\${sourcePath} to \\${remoteDest}`);",
      "    await uploadDirectory(client, sourcePath, remoteDest);",
      "",
      "    console.log(\"Deployment completed successfully!\");",
      "  } catch (error) {",
      "    console.error(\"Deployment failed:\", error);",
      "    process.exit(1);",
      "  } finally {",
      "    client.close();",
      "  }",
      "}",
      "",
      "const source = process.argv[2];",
      "const destination = process.argv[3];",
      "",
      "if (!source || !destination) {",
      "  console.error(\"Usage: npx tsx deploy.ts <source> <destination>\");",
      "  process.exit(1);",
      "}",
      "",
      "deploy(source, destination);"
    ]
  },
