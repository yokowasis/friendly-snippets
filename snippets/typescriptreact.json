      "};",
      "",
      "export const getStaticProps = async () => {",
      "  const res = await fetch('https://jsonplaceholder.typicode.com/posts/1');",
      "  const post: Post = await res.json();",
      "",
      "  return {",
      "    props: { post },",
      "  };",
      "};",
      "",
      "type StaticProps = {",
      "  post: Post;",
      "};",
      "",
      "const ${1:StaticPage}: React.FC<StaticProps> = ({ post }) => (",
