{
  "pb-autoincrement": {
    "prefix": "pb-autoincrement",
    "body": [
      "// Usage : setupAutoIncrement(app, \"ca_invoice\")",
      "// Panduan : https://docs.bimasoft.web.id/images/private/pb_autoincrement.png",
      "func setupAutoIncrement(app *pocketbase.PocketBase, tableName string) {",
      "  app.OnRecordCreate(tableName).BindFunc(func(e *core.RecordEvent) error {",
      "    var result struct {",
      "      Value int `db:\"value\"`",
      "    }",
      "",
      "    err := app.DB().NewQuery(fmt.Sprintf(`",
      "      UPDATE counters",
      "      SET value = value + 1",
      "      WHERE name = '%s'",
      "      RETURNING value",
      "    `, tableName)).One(&result)",
      "    if err != nil {",
      "      return err",
      "    }",
      "",
      "    e.Record.Set(tableName+\"_id\", result.Value)",
      "    return e.Next()",
      "  })",
      "}",
      ""
    ]
  },
