  "express-gin": {
    "prefix": "express-gin",
    "body": [
      "package main",
      "",
      "import (",
      "  \"net/http\"",
      "",
      "  \"github.com/gin-gonic/gin\"",
      ")",
      "",
      "// User struct for JSON binding",
      "type User struct {",
      "  Name  string `json:\"name\" binding:\"required\"`",
      "  Email string `json:\"email\" binding:\"required\"`",
      "  Age   int    `json:\"age\"`",
      "}",
      "",
      "// UserForm struct for form binding",
      "type UserForm struct {",
      "  Name  string `form:\"name\" binding:\"required\"`",
      "  Email string `form:\"email\" binding:\"required\"`",
      "  Age   int    `form:\"age\"`",
      "}",
      "",
      "func main() {",
      "  r := gin.Default()",
      "",
      "  // GET /hello - returns JSON {\"hello\":\"world\"}",
      "  r.GET(\"/hello\", func(c *gin.Context) {",
      "    c.JSON(http.StatusOK, gin.H{",
      "      \"hello\": \"world\",",
      "    })",
      "  })",
      "",
      "  // POST /users/:id - example with dynamic route parameter and query parameter",
      "  // Example: POST /users/123?action=activate",
      "  r.POST(\"/users/:id\", func(c *gin.Context) {",
      "    // Get dynamic route parameter",
      "    id := c.Param(\"id\")",
      "",
      "    // Get query parameter",
      "    action := c.Query(\"action\")",
      "",
      "    c.JSON(http.StatusOK, gin.H{",
      "      \"user_id\": id,",
      "      \"action\":  action,",
      "      \"message\": \"User action processed\",",
      "    })",
      "  })",
      "",
      "  // POST /create-json - accepts JSON body",
      "  // Example: {\"name\":\"John Doe\",\"email\":\"john@example.com\",\"age\":30}",
      "  r.POST(\"/create-json\", func(c *gin.Context) {",
      "    var user User",
      "",
      "    // Bind JSON body to User struct",
      "    if err := c.ShouldBindJSON(&user); err != nil {",
      "      c.JSON(http.StatusBadRequest, gin.H{",
      "        \"error\": err.Error(),",
      "      })",
      "      return",
      "    }",
      "",
      "    c.JSON(http.StatusOK, gin.H{",
      "      \"message\": \"User created successfully from JSON\",",
      "      \"data\":    user,",
      "    })",
      "  })",
      "",
      "  // POST /create-form - accepts form data (application/x-www-form-urlencoded or multipart/form-data)",
      "  // Example form data: name=Jane Doe&email=jane@example.com&age=25",
      "  r.POST(\"/create-form\", func(c *gin.Context) {",
      "    var userForm UserForm",
      "",
      "    // Bind form data to UserForm struct",
      "    if err := c.ShouldBind(&userForm); err != nil {",
      "      c.JSON(http.StatusBadRequest, gin.H{",
      "        \"error\": err.Error(),",
      "      })",
      "      return",
      "    }",
      "",
      "    c.JSON(http.StatusOK, gin.H{",
      "      \"message\": \"User created successfully from form\",",
      "      \"data\":    userForm,",
      "    })",
      "  })",
      "",
      "  r.Run(\":8080\")",
      "}",
      ""
    ]
  },
