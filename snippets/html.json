  "html:preact": {
    "prefix": "html:preact",
    "body": [
      "<!doctype html>",
      "<html lang=\"en\">",
      "\t<head>",
      "\t\t<meta charset=\"UTF-8\" />",
      "\t\t<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />",
      "\t\t<title>Preact Routing with Example</title>",
      "",
      "\t\t<!-- Load Preact from CDN -->",
      "\t\t<script src=\"https://unpkg.com/preact@latest/dist/preact.min.js\"></script>",
      "\t\t<script src=\"https://unpkg.com/preact@latest/hooks/dist/hooks.umd.js\"></script>",
      "\t\t<script src=\"https://unpkg.com/htm@latest/dist/htm.js\"></script>",
      "\t</head>",
      "\t<body>",
      "\t\t<div id=\"app\"></div>",
      "",
      "\t\t<!-- 1. Initialize Preact and HTM (global scope) -->",
      "\t\t<script>",
      "\t\t\tconst { h, render, Component } = preact;",
      "\t\t\tconst { useState, useEffect, useMemo } = preactHooks;",
      "\t\t\tconst html = htm.bind(h);",
      "\t\t</script>",
      "",
      "\t\t<!-- 2. Load Modules (order matters!) -->",
      "\t\t<script>",
      "\t\t\tfunction useHashRouter() {",
      "\t\t\t\tconst [route, setRoute] = useState(window.location.hash || \"#/\");",
      "",
      "\t\t\t\tuseEffect(() => {",
      "\t\t\t\t\tconst onHashChange = () => setRoute(window.location.hash || \"#/\");",
      "\t\t\t\t\twindow.addEventListener(\"hashchange\", onHashChange);",
      "\t\t\t\t\treturn () => window.removeEventListener(\"hashchange\", onHashChange);",
      "\t\t\t\t}, []);",
      "",
      "\t\t\t\tconst navigate = (path) => {",
      "\t\t\t\t\twindow.location.hash = path;",
      "\t\t\t\t};",
      "",
      "\t\t\t\treturn { route, navigate };",
      "\t\t\t}",
      "\t\t</script>",
      "",
      "\t\t<script>",
      "\t\t\tfunction HomePage({ navigate }) {",
      "\t\t\t\tconst [name, setName] = useState(\"\");",
      "",
      "\t\t\t\tuseEffect(() => {",
      "\t\t\t\t\tconst storedName = \"Yoko\";",
      "\t\t\t\t\tif (storedName) {",
      "\t\t\t\t\t\tsetName(storedName);",
      "\t\t\t\t\t}",
      "\t\t\t\t}, []);",
      "",
      "\t\t\t\treturn html`",
      "\t\t\t\t\t<div>",
      "\t\t\t\t\t\t<h1>Home Page</h1>",
      "\t\t\t\t\t\t<p>Welcome to the home page! \\${name}</p>",
      "\t\t\t\t\t</div>",
      "\t\t\t\t`;",
      "\t\t\t}",
      "\t\t</script>",
      "",
      "\t\t<script>",
      "\t\t\tfunction App() {",
      "\t\t\t\tconst { route, navigate } = useHashRouter();",
      "",
      "\t\t\t\t// Simple route matching",
      "\t\t\t\tlet page;",
      "\t\t\t\tif (route === \"#/\" || route === \"#/home\") {",
      "\t\t\t\t\tpage = html`<\\${HomePage} navigate=\\${navigate} />`;",
      "\t\t\t\t} else {",
      "\t\t\t\t\tpage = html`<\\${NotFoundPage} navigate=\\${navigate} />`;",
      "\t\t\t\t}",
      "",
      "\t\t\t\treturn html`",
      "\t\t\t\t\t<div class=\"container\">",
      "\t\t\t\t\t\t<h2>Current Route: \\${route}</h2>",
      "",
      "\t\t\t\t\t\t\\${page}",
      "\t\t\t\t\t</div>",
      "\t\t\t\t`;",
      "\t\t\t}",
      "\t\t</script>",
      "",
      "\t\t<!-- 3. Render the app -->",
      "\t\t<script>",
      "\t\t\trender(html`<\\${App} />`, document.getElementById(\"app\"));",
      "\t\t</script>",
      "\t</body>",
      "</html>",
      ""
    ]
